# Copy to `backend/.env` (gitignored). Do not commit real keys.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Two extra LLM calls after each draft: evaluator JSON + refiner letter (side-by-side in UI when enabled)
# EVALUATOR_DUAL_DRAFT=false
CORS_ORIGINS=http://localhost:3000
# Post–free-trial signed-in daily cap (UTC calendar day)
DAILY_LIMIT_AUTHENTICATED=10
# Higher cap during the first TRIAL_PERIOD_DAYS after first sign-in activity (SQLite `TRIAL_DB_PATH`)
DAILY_LIMIT_TRIAL=50
TRIAL_PERIOD_DAYS=7
# TRIAL_DB_PATH=
# Display / future billing: base tier positioning (actual INR charge not enforced here yet)
BASE_TIER_PRICE_INR=1
# Signed-in users with an active Stripe subscription (webhook → DB) use this cap instead
DAILY_LIMIT_PRO=500
DAILY_LIMIT_ANONYMOUS=15
# Phase 6: max pipeline clarification rounds (0-based; old default was 2; clamp 1–20 in app)
# CLARIFICATION_MAX_ROUNDS=8
# Optional: SQLite file for Clerk ↔ subscription rows (default `var/entitlements.sqlite` under cwd)
# ENTITLEMENTS_DB_PATH=
# Multi-instance: Postgres instead of SQLite (see backend/docs/ENTITLEMENTS_POSTGRES.md)
# ENTITLEMENTS_DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# P8-01: SQLite file for `/dashboard` saved cases (default `var/dashboard_cases.sqlite`)
# CASES_DB_PATH=
# P8-02: SQLite file for lightweight thumbs feedback analytics (default `var/response_feedback.sqlite`)
# FEEDBACK_DB_PATH=
# SQLite file for signed-in chat thread history (default `var/chat_history.sqlite`)
# CHAT_HISTORY_DB_PATH=
# Horizontal scaling: shared daily rate-limit counters (see backend/docs/RATE_LIMIT_REDIS.md)
# REDIS_URL=redis://localhost:6379/0
# Product: none | stub | stripe (see GET /config, docs/STRIPE.md)
BILLING_MODE=none
# Stripe (only when BILLING_MODE=stripe): Checkout + webhook
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_APP_URL=http://localhost:3000
# Optional JSON field `client_mode` (citizen|lawyer) or header X-Client-Mode — see docs/CLIENT_MODE_DESIGN.md (not env)
# Comma-separated subset advertised to the UI on GET /config and GET /ready (default citizen,lawyer)
# CLIENT_MODES_SUPPORTED=citizen,lawyer
# P1-1: when true, client_mode=lawyer requires non-empty X-User-Id (sign in via Clerk in the app)
# LAWYER_CLIENT_MODE_REQUIRES_USER_ID=false
# P1-1: when BILLING_MODE=stripe, also require an active Pro row in entitlements (Stripe webhook) for client_mode=lawyer.
# LAWYER_CLIENT_MODE_REQUIRES_PRO=false
# S3: optional `python -m app.rag.jobs.ingest_statutes --s3-uri s3://…/prefix/` (boto3; see RAG_PINECONE_RUNBOOK.md)
# AWS_DEFAULT_REGION=ap-south-1
# RAG: local (default) or pinecone; require PINECONE_* and ingest for pinecone
RAG_VECTOR_STORE=local
# PINECONE_API_KEY=
# PINECONE_INDEX=nyaya-legal-kb
# PINECONE_NAMESPACE=
# PINECONE_QUERY_CANDIDATES=48
# Optional: larger Pinecone pre-fetch for lawyer (clamped 8–200; unset = base+24 up to 200)
# PINECONE_QUERY_CANDIDATES_LAWYER=
# Strict RAG top_k by client_mode (body/header `client_mode`); clamped 3–24
# RAG_TOP_K_CITIZEN=8
# RAG_TOP_K_LAWYER=12
# Alias for RAG_TOP_K_CITIZEN (same setting)
# RAG_TOP_K_DEFAULT=8
# Sprint 6: case-law research adapter (GET /config → `case_law_research_mode`)
# off = hide panel, noop = show empty panel, tavily_preview = external web snippets (requires TAVILY_API_KEY)
# CASE_LAW_MODE=off
# CASE_LAW_MAX_RESULTS=5
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# Image OCR (P3-01): none | openai | textract | tesseract — see backend/docs/OCR_AND_AWS.md
# INGEST_OCR_PROVIDER=none
# INGEST_OCR_MAX_LONG_EDGE_PX=2000
# INGEST_OCR_OPENAI_MODEL=gpt-4o-mini
# INGEST_OCR_OPENAI_MAX_TOKENS=2048
# INGEST_OCR_TESSERACT_LANG=eng
# INGEST_OCR_PDF_MAX_PAGES=3
# AWS_REGION=ap-south-1
