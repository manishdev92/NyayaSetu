# Secrets: never commit real .env; templates (*.env.example) are OK
**/.env
!**/.env.example
!**/.env.*.example
**/.clerk/
backend/.venv/
backend/**/__pycache__/
# frontend/ — see frontend/.gitignore; common Next patterns at repo root
frontend/.env.local
frontend/.next/
frontend/node_modules/
backend/logs/llm_fallback_cases.json
backend/logs/authority_mismatch.json
backend/var/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
