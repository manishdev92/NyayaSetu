# Copy to ".env" (gitignored) and fill in. Do not commit .env
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: shown on /contact and /hi/contact as mailto (marketing GTM)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
# Canonical site URL for metadata (see app/layout.tsx)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional `client_mode` / lawyer toggle is sent on generate JSON (see docs/CLIENT_MODE_DESIGN.md), not an env var.
# P1-4: when "1", show citizen/lawyer toggle if GET /config includes `lawyer` in `client_modes_supported` (rebuild after change).
# NEXT_PUBLIC_LAWYER_MODE_UI=1
# P2-4: when "1", show letter / Q&A / both response-style selector; sends `task_type` on generate (rebuild after change).
# NEXT_PUBLIC_RESPONSE_TASK_UI=1
# S6: case-law research panel (lawyer mode) when API GET /config has `case_law_research_mode` not `off` (rebuild after change)
# NEXT_PUBLIC_CASE_LAW_UI=1
# P7-03: when "1", auto-run the oldest queued generate when the browser fires `online` (see LegalChat).
# NEXT_PUBLIC_AUTO_RETRY_QUEUE_ONLINE=1
# P7-03 (remainder): when "1", persist the offline generate queue in IndexedDB (larger cap) instead of localStorage only.
# NEXT_PUBLIC_OFFLINE_QUEUE_IDB=1
# From Clerk dashboard (Dashboard → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# P7-01: service worker registers only in production (`next start`). Set to 1 to disable SW in prod builds.
# NEXT_PUBLIC_DISABLE_SW=
