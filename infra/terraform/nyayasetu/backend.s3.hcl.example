# Copy to backend.s3.hcl, fill the bucket, then (first time only, moving local .tfstate to S3):
#   terraform init -backend-config=backend.s3.hcl -migrate-state
# (Do not combine -migrate-state with -reconfigure; they are mutually exclusive.)
# If state is already in S3 and you are only re-pointing the CLI:
#   terraform init -reconfigure -backend-config=backend.s3.hcl
#
# Create the bucket in the same region you use for the stack (e.g. ap-south-1).
# Optional: DynamoDB for state locking (recommended) — use the same name here.

bucket         = "your-account-nyayasetu-terraform-state"
key            = "nyayasetu/terraform.tfstate"
region         = "ap-south-1"
encrypt        = true
# dynamodb_table = "nyayasetu-terraform-locks"
